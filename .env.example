# Mapbox — address autocomplete (Central Florida quote form)
# Get a public access token at https://account.mapbox.com/access-tokens/
# Required for the AddressInput component to suggest addresses.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Google Maps — embedded route map + Places (New) autocomplete on /quote.
# Enable "Maps Embed API" + "Places API (New)", restrict the key by HTTP referrer.
# Without it the map falls back to a placeholder and autocomplete to a plain input.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps — SERVER-side key for driving distance in lead notifications.
# Separate key: enable "Routes API", NO referrer restriction (server calls have
# none), restrict it to Routes API only. Optional — distance is skipped without it.
GOOGLE_MAPS_SERVER_KEY=

# Resend — send quote requests + customer confirmation
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@toromovers.net
BOOKING_NOTIFICATION_EMAIL=hello@toromovers.net

# Site
NEXT_PUBLIC_SITE_URL=https://toromovers.netlify.app
